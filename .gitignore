# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Environment variables
.env

# Firebase Admin SDK service account key — DO NOT COMMIT
.secrets/
*.serviceaccount.json

# Local CSV backups
*.csv.bak
# Claude Code local state
.claude/

# Cloud Functions build output
functions/lib/
functions/node_modules/

# Asset source files (uploaded to Firebase Storage via scripts/upload-assets.ts)
/assets/
