// === Ember Crown Firestore Security Rules ===
// Phase 5.75 — production-correct rules replacing test mode.
//
// ROLE MODEL:
//   - Public collections (card_library, commander_library): read-only for all auth
//   - Player-owned collections (profiles, wallets, inventories, decks):
//       owner can read; only certain fields/collections are owner-writable
//   - Match collections (match_sessions, live_board_state):
//       client read-only; all writes via Cloud Functions
//
// KNOWN V2 HARDENING:
//   - live_board_state read should validate match participation via cross-doc get()
//     Currently any auth user can iterate. Acceptable v1 risk; revisit when PvP ships.
//   - player_active_decks/slots write doesn't validate inventory ownership
//     Acceptable v1 risk; client-side validation is sufficient for non-escalating cheats.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPER FUNCTIONS ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMatchParticipant(matchData) {
      return isSignedIn() && (
        request.auth.uid == matchData.player_a_id ||
        request.auth.uid == matchData.player_b_id
      );
    }

    // Profile field-level guard: caller can update only safe fields, with
    // additional value-bounded checks on a couple of them.
    //
    // Allowed for client write:
    //   - username, updated_at: free-form
    //   - selected_commander: free-form (deck builder updates this)
    //   - active_faction: only when previously unset (onboarding picker sets it once;
    //       Phase 7 will manage multi-faction unlocks via Cloud Function)
    //   - onboarding_step: only values ≤ 3 (the 3 → 4 transition is gated by
    //       completeOnboardingFn; this prevents a client from skipping straight to 4
    //       to bypass wallet/inventory provisioning)
    //
    // Forbidden for client write (Cloud Functions / admin only):
    //   unlocked_factions, solo_unlocked_factions, tutorial_reward_claimed,
    //   tutorial_completed, created_at, player_id
    //
    // The allowlist below is exhaustive — any field not listed (including
    // solo_unlocked_factions, added in Phase 9.4.4) is automatically denied
    // on client writes. The recompute helper writes solo_unlocked_factions
    // via the Admin SDK from inside summonCard / craftCard transactions.
    function profileUpdateIsSafe() {
      let allowedFields = [
        'username',
        'selected_commander',
        'active_faction',
        'onboarding_step',
        'battle_mode_decks_shareable',
        'fired_analytics_events',
        'updated_at',
      ];
      let changedFields = request.resource.data.diff(resource.data).affectedKeys();
      return changedFields.hasOnly(allowedFields)
        && (
          !changedFields.hasAny(['onboarding_step'])
          || request.resource.data.onboarding_step <= 3
        )
        && (
          !changedFields.hasAny(['active_faction'])
          || resource.data.active_faction == null
        );
    }

    // === PUBLIC SEED COLLECTIONS ===
    // card_library and commander_library: read-only for everyone, no client writes.
    // Updates happen via the Admin SDK seed script, which bypasses rules.
    match /card_library/{cardId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /commander_library/{commanderId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // campaign_stages: 54 docs seeded via Admin SDK (Phase 5.5).
    // Read-only for any authenticated client; Phase 7 reads stage definitions
    // when launching a campaign match.
    match /campaign_stages/{stageId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // === PLAYER PROFILE ===
    match /player_profiles/{uid} {
      allow read: if isOwner(uid);
      // Create on first sign-in: client creates the doc with defaults.
      allow create: if isOwner(uid);
      // Update: gated by profileUpdateIsSafe (see helper above for allowed
      // fields and value-bounded checks).
      allow update: if isOwner(uid) && profileUpdateIsSafe();
      // Delete: never from client.
      allow delete: if false;
    }

    // === PLAYER WALLET ===
    match /player_wallets/{uid} {
      // Owner can read their wallet.
      allow read: if isOwner(uid);
      // No client writes — Cloud Functions only (admin SDK bypasses rules).
      allow write: if false;
    }

    // === PLAYER INVENTORY ===
    match /player_inventories/{uid} {
      // The parent doc is empty / structural; allow read so subcol queries work.
      allow read: if isOwner(uid);
      allow write: if false;

      match /cards/{cardId} {
        allow read: if isOwner(uid);
        allow write: if false;  // Cloud Functions only
      }
    }

    // === PLAYER ACTIVE DECK ===
    match /player_active_decks/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;  // No writes to parent

      match /slots/{slotId} {
        // Owner can read and write their own slots.
        // (Deck builder writes here directly — no quantity validation in rules,
        // client-side checks are sufficient for v1.)
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
    }

    // === PLAYER SAVED DECKS (Phase 9.4.5) ===
    // 3 deck slots per faction (max 18 docs per uid). Owner-readable for
    // Guild Hall + match flow. All writes go through Cloud Functions
    // (saveDeck / deleteSavedDeck / setActiveSavedDeck) for power-score
    // computation, ownership validation, and 4-copy enforcement.
    //
    // Battle Mode opponent matchmaking reads other players' saved decks via
    // Admin SDK (bypasses rules). Direct cross-uid reads from clients are
    // not allowed.
    match /player_saved_decks/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;

      match /decks/{deckId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // === PLAYER CAMPAIGN PROGRESS ===
    // One doc per player tracking faction stage completions, first-win timestamps,
    // and reward-claim flags. Created and updated only by Cloud Functions
    // (Phase 7 will add a recordCampaignWin function); the owner can read.
    match /player_campaign_progress/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // === MATCH SESSIONS ===
    match /match_sessions/{matchId} {
      // Read: only participants.
      allow read: if isSignedIn() && isMatchParticipant(resource.data);
      // No client writes — Cloud Functions only.
      allow write: if false;
    }

    // === LIVE BOARD STATE ===
    match /live_board_state/{instanceId} {
      // Read: anyone signed in (cross-doc participant check is too expensive
      //   in rules — we accept that a malicious client could iterate
      //   live_board_state and read board states of in-progress matches.
      //   Acceptable v1 risk because:
      //   1. They'd need to know match IDs which aren't broadcast.
      //   2. Reading doesn't enable cheating — bot decisions are server-side.
      //   3. PvP doesn't ship until much later.
      //   See V2 HARDENING note at top of file.)
      allow read: if isSignedIn();
      // No client writes — Cloud Functions only.
      allow write: if false;
    }
  }
}
