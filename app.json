{
  "expo": {
    "name": "ember-crown",
    "slug": "ember-crown",
    "scheme": "embercrown",
    "version": "1.2.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.embercrown.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "15",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.embercrown.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 19,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#1a1a2e"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAnalytics",
              "RNFBCrashlytics"
            ]
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4913659728698968~5346962539",
          "iosAppId": "ca-app-pub-4913659728698968~9952806397"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0f"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.903632353042-hv7jed3m5icii256q5snbsblrqett9h2"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f69b2d1-5375-492e-8606-259a75b8ce67"
      }
    }
  }
}
